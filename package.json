{
  "name": "pencil-sync",
  "version": "0.1.2",
  "description": "Bidirectional sync between .pen design files and frontend code via Claude CLI",
  "license": "Apache-2.0",
  "author": "pencil-sync contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/celstnblacc/pencil-sync.git"
  },
  "keywords": [
    "pencil",
    "design-to-code",
    "claude",
    "sync",
    "pen-files",
    "bidirectional",
    "AI",
    "frontend"
  ],
  "files": [
    "dist/",
    "!dist/__tests__/",
    "prompts/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "bin": {
    "pencil-sync": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "watch": "node dist/index.js watch",
    "sync": "node dist/index.js sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
